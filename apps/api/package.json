{
  "name": "@sautiledger/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint config will be added with the first test pass\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "INTEGRATION=1 vitest run",
    "migration:run": "tsx src/scripts/migrate.ts run",
    "migration:revert": "tsx src/scripts/migrate.ts revert",
    "migration:show": "tsx src/scripts/migrate.ts show",
    "seed": "tsx src/scripts/seed.ts",
    "seed:demo": "tsx src/scripts/seed-demo.ts"
  },
  "dependencies": {
    "@sautiledger/shared": "0.1.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.73.0",
    "pg": "^8.13.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.15.0",
    "pino-pretty": "^11.3.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
